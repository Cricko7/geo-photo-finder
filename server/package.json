{
  "name": "geo-photo-finder-server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --coverage --forceExit --detectOpenHandles --verbose --testTimeout=30000",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --forceExit --detectOpenHandles --verbose --maxWorkers=2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "forceExit": true,
    "detectOpenHandles": true,
    "verbose": true,
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "**/*.js",
      "!**/node_modules/**",
      "!**/tests/**",
      "!**/coverage/**"
    ]
  }
}