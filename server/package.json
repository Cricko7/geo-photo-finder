{
  "name": "geo-photo-finder-server",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exifr": "^7.1.3",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --coverage --forceExit --detectOpenHandles --verbose --testTimeout=30000",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --forceExit --detectOpenHandles --verbose --maxWorkers=2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "forceExit": true,
    "detectOpenHandles": true,
    "verbose": true,
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "**/*.js",
      "!**/node_modules/**",
      "!**/tests/**",
      "!**/coverage/**"
    ]
  }
}
