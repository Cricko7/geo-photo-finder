{
  "name": "geo-photo-finder-server",
  "version": "1.0.0",
  "description": "Geo Photo Finder Backend API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --coverage --forceExit --detectOpenHandles --verbose",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --forceExit --detectOpenHandles --verbose"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "exifr": "^7.1.3",
    "sharp": "^0.32.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "winston": "^3.10.0",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "jest": "^29.6.4",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "forceExit": true,
    "detectOpenHandles": true,
    "verbose": true,
    "testTimeout": 10000,
    "collectCoverageFrom": [
      "**/*.js",
      "!**/node_modules/**",
      "!**/tests/**",
      "!**/coverage/**"
    ]
  }
}